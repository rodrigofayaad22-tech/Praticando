import java.io.*;
import java.security.MessageDigest;
import java.security.NoSuchAlgorithmException;
import java.util.ArrayList;
import java.util.Scanner;

class Usuario {
    private String nome;
    private String email;
    private String senhaHash;

    public Usuario(String nome, String email, String senhaHash) {
        this.nome = nome;
        this.email = email;
        this.senhaHash = senhaHash;
    }

    public String getNome() {
        return nome;
    }

    public String getEmail() {
        return email;
    }

    public String getSenhaHash() {
        return senhaHash;
    }

    public void setSenhaHash(String senhaHash) {
        this.senhaHash = senhaHash;
    }

    public String transformarEmLinhaArquivo() {
        return nome + ";" + email + ";" + senhaHash;
    }
}

class SistemaUsuarios {
    private ArrayList<Usuario> usuarios;
    private final String nomeArquivo = "usuarios.txt";

    public SistemaUsuarios() {
        usuarios = new ArrayList<>();
        carregarUsuarios();
    }

    public void cadastrarUsuario(String nome, String email, String senha) {
        if (nome.isBlank() || email.isBlank() || senha.isBlank()) {
            System.out.println("Erro: nenhum campo pode ficar vazio.");
            return;
        }

        if (!email.contains("@")) {
            System.out.println("Erro: email inválido.");
            return;
        }

        if (senha.length() < 6) {
            System.out.println("Erro: a senha deve ter pelo menos 6 caracteres.");
            return;
        }

        if (buscarPorEmail(email) != null) {
            System.out.println("Erro: já existe um usuário com esse email.");
            return;
        }

        String senhaHash = criptografarSenha(senha);

        Usuario usuario = new Usuario(nome, email, senhaHash);
        usuarios.add(usuario);

        salvarUsuarios();

        System.out.println("Usuário cadastrado com sucesso!");
    }

    public Usuario fazerLogin(String email, String senha) {
        Usuario usuario = buscarPorEmail(email);

        if (usuario == null) {
            System.out.println("Erro: usuário não encontrado.");
            return null;
        }

        String senhaDigitadaHash = criptografarSenha(senha);

        if (!usuario.getSenhaHash().equals(senhaDigitadaHash)) {
            System.out.println("Erro: senha incorreta.");
            return null;
        }

        System.out.println("Login realizado com sucesso!");
        return usuario;
    }

    public void alterarSenha(Usuario usuarioLogado, String senhaAtual, String novaSenha) {
        String senhaAtualHash = criptografarSenha(senhaAtual);

        if (!usuarioLogado.getSenhaHash().equals(senhaAtualHash)) {
            System.out.println("Erro: senha atual incorreta.");
            return;
        }

        if (novaSenha.length() < 6) {
            System.out.println("Erro: a nova senha deve ter pelo menos 6 caracteres.");
            return;
        }

        String novaSenhaHash = criptografarSenha(novaSenha);
        usuarioLogado.setSenhaHash(novaSenhaHash);

        salvarUsuarios();

        System.out.println("Senha alterada com sucesso!");
    }

    public Usuario buscarPorEmail(String email) {
        for (Usuario usuario : usuarios) {
            if (usuario.getEmail().equalsIgnoreCase(email)) {
                return usuario;
            }
        }

        return null;
    }

    private void salvarUsuarios() {
        try {
            BufferedWriter writer = new BufferedWriter(new FileWriter(nomeArquivo));

            for (Usuario usuario : usuarios) {
                writer.write(usuario.transformarEmLinhaArquivo());
                writer.newLine();
            }

            writer.close();

        } catch (IOException e) {
            System.out.println("Erro ao salvar usuários.");
        }
    }

    private void carregarUsuarios() {
        File arquivo = new File(nomeArquivo);

        if (!arquivo.exists()) {
            return;
        }

        try {
            BufferedReader reader = new BufferedReader(new FileReader(nomeArquivo));

            String linha;

            while ((linha = reader.readLine()) != null) {
                String[] dados = linha.split(";");

                if (dados.length == 3) {
                    String nome = dados[0];
                    String email = dados[1];
                    String senhaHash = dados[2];

                    Usuario usuario = new Usuario(nome, email, senhaHash);
                    usuarios.add(usuario);
                }
            }

            reader.close();

        } catch (IOException e) {
            System.out.println("Erro ao carregar usuários.");
        }
    }

    private String criptografarSenha(String senha) {
        try {
            MessageDigest digest = MessageDigest.getInstance("SHA-256");

            byte[] hashBytes = digest.digest(senha.getBytes());

            StringBuilder senhaCriptografada = new StringBuilder();

            for (byte b : hashBytes) {
                senhaCriptografada.append(String.format("%02x", b));
            }

            return senhaCriptografada.toString();

        } catch (NoSuchAlgorithmException e) {
            throw new RuntimeException("Erro ao criptografar senha.");
        }
    }
}

public class sistemalogin {

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        SistemaUsuarios sistema = new SistemaUsuarios();

        Usuario usuarioLogado = null;
        int opcao;

        do {
            System.out.println("\n=== SISTEMA DE LOGIN ===");

            if (usuarioLogado == null) {
                System.out.println("1 - Cadastrar usuário");
                System.out.println("2 - Fazer login");
                System.out.println("3 - Sair");
            } else {
                System.out.println("1 - Acessar área restrita");
                System.out.println("2 - Alterar senha");
                System.out.println("3 - Logout");
                System.out.println("4 - Sair");
            }

            System.out.print("Escolha uma opção: ");
            opcao = scanner.nextInt();
            scanner.nextLine();

            if (usuarioLogado == null) {
                switch (opcao) {
                    case 1:
                        System.out.print("Digite seu nome: ");
                        String nome = scanner.nextLine();

                        System.out.print("Digite seu email: ");
                        String emailCadastro = scanner.nextLine();

                        System.out.print("Digite sua senha: ");
                        String senhaCadastro = scanner.nextLine();

                        sistema.cadastrarUsuario(nome, emailCadastro, senhaCadastro);
                        break;

                    case 2:
                        System.out.print("Digite seu email: ");
                        String emailLogin = scanner.nextLine();

                        System.out.print("Digite sua senha: ");
                        String senhaLogin = scanner.nextLine();

                        usuarioLogado = sistema.fazerLogin(emailLogin, senhaLogin);
                        break;

                    case 3:
                        System.out.println("Encerrando sistema...");
                        break;

                    default:
                        System.out.println("Opção inválida!");
                }
            } else {
                switch (opcao) {
                    case 1:
                        System.out.println("\n=== ÁREA RESTRITA ===");
                        System.out.println("Bem-vindo, " + usuarioLogado.getNome() + "!");
                        System.out.println("Você está acessando uma área protegida.");
                        break;

                    case 2:
                        System.out.print("Digite sua senha atual: ");
                        String senhaAtual = scanner.nextLine();

                        System.out.print("Digite sua nova senha: ");
                        String novaSenha = scanner.nextLine();

                        sistema.alterarSenha(usuarioLogado, senhaAtual, novaSenha);
                        break;

                    case 3:
                        usuarioLogado = null;
                        System.out.println("Logout realizado com sucesso!");
                        break;

                    case 4:
                        System.out.println("Encerrando sistema...");
                        break;

                    default:
                        System.out.println("Opção inválida!");
                }
            }

        } while ((usuarioLogado == null && opcao != 3) || (usuarioLogado != null && opcao != 4));

        scanner.close();
    }
}
